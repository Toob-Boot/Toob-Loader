{
    "esp32-c6": {
        "arch": "RISC-V",
        "boot_vectors": {
            "rom_base": "0x40000000",
            "user_app_base": "0x42000000"
        },
        "memory": {
            "alignment_bytes": 16,
            "bootrom_reserved_data_bytes": 0,
            "data_segment": "hp_sram",
            "executable_segment": "hp_sram",
            "memory_regions": [
                {
                    "length": "0x50000",
                    "name": "rom",
                    "origin": "0x40000000",
                    "permissions": "rx"
                },
                {
                    "length": "0x80000",
                    "name": "hp_sram",
                    "origin": "0x40800000",
                    "permissions": "rwx"
                },
                {
                    "length": "0x4000",
                    "name": "lp_sram",
                    "origin": "0x50000000",
                    "permissions": "rwx"
                }
            ],
            "vector_alignment_section": ".vectors",
            "vector_table_offset_bytes": 0
        },
        "security_registers": {
            "flash_encryption": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": {}
            },
            "jtag_disabled": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": {}
            },
            "rdp_level": {
                "bit_mask": {},
                "register_addr": {}
            }
        },
        "startup": {
            "abi_initialization_instructions": [
                ".option push",
                ".option norelax",
                "la gp, __global_pointer$",
                ".option pop"
            ],
            "bss_init_required": true,
            "stack_top_expression": "ORIGIN(hp_sram) + LENGTH(hp_sram)"
        },
        "toolchain_requirements": {
            "compiler_prefix": "riscv32-esp-elf-",
            "core_architecture": "RISC-V",
            "flashing": {
                "flash_offset": "0x0",
                "method": "UART / USB Serial/JTAG",
                "tool": "esptool.py",
                "write_command": "esptool.py --chip esp32c6 write_flash 0x0 {binary_path}"
            },
            "packaging": [
                {
                    "command": "esptool.py --chip esp32c6 elf2image --flash_mode dio --flash_freq 40m --flash_size 2MB -o {binary_path} {elf_path}",
                    "condition": "ANY",
                    "tool": "esptool.py"
                },
                {
                    "command": "espsecure.py sign_data --version 2 --keyfile {private_key_path} -o {binary_path} {binary_path}",
                    "condition": "PROFILE_SECURE_BOOT_ONLY",
                    "tool": "espsecure.py"
                }
            ]
        },
        "watchdog_kill_registers": []
    }
}