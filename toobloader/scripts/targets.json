    "__planned_stm32_architectures__": {
      "status": "planned",
      "architectures": [
        "stm32f0", "stm32f2", "stm32f3", "stm32f7",
        "stm32l0", "stm32l1", "stm32l4", "stm32l5",
        "stm32g0", "stm32c0", "stm32w", "stm32h5"
      ],
      "note": "These architectures share the Cortex-M cores but require dedicated Flash HALs. Implementation is planned for a future Repowatt-OS milestone."
    }
  }
}