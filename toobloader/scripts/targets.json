      "sub_family": "h7",
      "arch": "arm",
      "compiler": "arm-none-eabi-gcc",
      "flash_offset": "0x08000000",
      "flash_size": "128K",
      "ram_size": "128K",
      "recovery_pin_rules": {
        "supported": true,
        "max_pin": 255,
        "blacklist": [
          13,
