{
    "flash_controller": {
        "read_word_sequence": [
            { 
                "type": "raw_c", 
                "code": "uint32_t p_page = sector_addr / 0x10000;\n    uint32_t p_offset = sector_addr % 0x10000;\n    FZ_LOG_DEBUG(\"[R1]\\n\");\n    #define DPORT_PRO_CACHE_CTRL_REG 0x3FF00040\n    /* PRO_MMU_TABLE Virtual 0x400D0000 mapped dynamically */\n    *((volatile uint32_t*)(0x3FF10000 + (13 * 4))) = p_page;\n    /* Flush hardware cache explicitly to prevent 64KB boundary arbiter crashes */\n    *((volatile uint32_t*)DPORT_PRO_CACHE_CTRL_REG) &= ~(1<<3);\n    *((volatile uint32_t*)DPORT_PRO_CACHE_CTRL_REG) |= (1<<3);\n    if (out_val) *out_val = *((volatile uint32_t*)(0x400D0000 + p_offset));",
                "desc": "MMU Seizure with Instant DPORT Cache Flush"
            }
        ],
        "unlock_sequence": [],
        "erase_sector_sequence": [
            {
                "type": "raw_c",
                "code": "FZ_LOG_DEBUG(\"[E1]\\n\");\n    #define DPORT_PRO_CACHE_CTRL_REG 0x3FF00040\n    *((volatile uint32_t*)DPORT_PRO_CACHE_CTRL_REG) &= ~(1<<3); // DPORT_HW_CACHE_DISABLE",
                "desc": "Kill Hardware DPORT Prefetch Pipeline to prevent SPI Arbiter Collisions"
            },
            {
                "type": "rom_function_call",
                "function_name": "SPIUnlock",
                "rom_address": "0x40062738",
                "args_csv": "",
                "requires_physical_offset": true,
                "desc": "Hardware BootROM Unlock"
            },
            { 
                "type": "rom_function_call", 
                "function_name": "SPIEraseSector", 
                "rom_address": "0x40062CCC", 
                "args_csv": "sector_addr / 4096", 
                "requires_physical_offset": true, 
                "desc": "Hardware BootROM Erase" 
            },
            {
                "type": "raw_c",
                "code": "*((volatile uint32_t*)DPORT_PRO_CACHE_CTRL_REG) |= (1<<3); // DPORT_HW_CACHE_ENABLE",
                "desc": "Restore Hardware DPORT Pipeline"
            }
        ],
        "write_word_sequence": [
            {
                "type": "raw_c",
                "code": "FZ_LOG_DEBUG(\"[W1]\\n\");\n    #define DPORT_PRO_CACHE_CTRL_REG 0x3FF00040\n    *((volatile uint32_t*)DPORT_PRO_CACHE_CTRL_REG) &= ~(1<<3);",
                "desc": "Kill Hardware DPORT Prefetch Pipeline"
            },
            {
                "type": "rom_function_call",
                "function_name": "SPIUnlock",
                "rom_address": "0x40062738",
                "args_csv": "",
                "requires_physical_offset": true,
                "desc": "Hardware BootROM Unlock"
            },
            {
                "type": "rom_function_call",
                "function_name": "SPIWriteWord",
                "rom_address": "0x40062D50",
                "args_csv": "sector_addr, &data_word, 4",
                "requires_physical_offset": true,
                "desc": "Hardware BootROM Write"
            },
            {
                "type": "raw_c",
                "code": "*((volatile uint32_t*)DPORT_PRO_CACHE_CTRL_REG) |= (1<<3);",
                "desc": "Restore Hardware DPORT Pipeline"
            }
        ]
    }
}
