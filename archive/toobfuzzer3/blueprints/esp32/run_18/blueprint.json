{
    "esp32": {
        "arch": "Xtensa (ESP32)",
        "boot_vectors": {
            "rom_base": "0x40000000",
            "user_app_base": "0x400C2000"
        },
        "memory": {
            "dram": {
                "alignment_bytes": 16,
                "length": "0x50000",
                "origin": "0x3FFB0000"
            },
            "iram": {
                "alignment_bytes": 16,
                "length": "0x20000",
                "origin": "0x40080000",
                "vector_table_offset_bytes": 1024
            }
        },
        "security_registers": {
            "flash_encryption": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": {}
            },
            "jtag_disabled": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": {}
            },
            "rdp_level": {
                "bit_mask": {},
                "register_addr": {}
            }
        },
        "startup": {
            "abi_initialization_instructions": [
                "movi a0, 0",
                "wsr a0, WINDOWBASE",
                "movi a0, 1",
                "wsr a0, WINDOWSTART",
                "rsync"
            ],
            "bss_init_required": true,
            "stack_top_expression": "ORIGIN(dram) + LENGTH(dram)"
        },
        "toolchain_requirements": {
            "compiler_prefix": "xtensa-esp32-elf-",
            "core_architecture": "Xtensa (ESP32)",
            "flashing": {
                "flash_offset": "0x1000",
                "method": "UART",
                "tool": "esptool.py",
                "write_command": "esptool.py write_flash 0x1000 {binary_path}"
            },
            "packaging": [
                {
                    "command": "esptool.py elf2image --flash_mode dio --flash_freq 40m --flash_size 2MB -o {binary_path} {elf_path}",
                    "condition": "ANY",
                    "tool": "esptool.py"
                },
                {
                    "command": "espsecure.py sign_data --version 2 --keyfile {private_key_path} --output {binary_path} {binary_path}",
                    "condition": "PROFILE_SECURE_BOOT_ONLY",
                    "tool": "espsecure.py"
                }
            ]
        },
        "watchdog_kill_registers": [
            {
                "address": "0x3FF5F064",
                "config_addr": "0x3FF5F048",
                "disable_val": "0x0",
                "name": "TIMG0_WDT",
                "unlock_val": "0x50D83AA1"
            },
            {
                "address": "0x3FF60064",
                "config_addr": "0x3FF60048",
                "disable_val": "0x0",
                "name": "TIMG1_WDT",
                "unlock_val": "0x50D83AA1"
            },
            {
                "address": "0x3FF480A4",
                "config_addr": "0x3FF4808C",
                "disable_val": "0x0",
                "name": "RTC_WDT",
                "unlock_val": "0x50D83AA1"
            }
        ]
    }
}