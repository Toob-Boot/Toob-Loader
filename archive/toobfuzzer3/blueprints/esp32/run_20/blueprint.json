{
    "esp32": {
        "arch": "Xtensa (ESP32)",
        "boot_vectors": {
            "rom_base": "0x40000000",
            "user_app_base": "0x400C2000"
        },
        "memory": {
            "alignment_bytes": 16,
            "data_segment": "internal_sram_2",
            "executable_segment": "internal_sram_0",
            "memory_regions": [
                {
                    "length": "0x60000",
                    "name": "internal_rom_0",
                    "origin": "0x40000000",
                    "permissions": "rx"
                },
                {
                    "length": "0x10000",
                    "name": "internal_rom_1",
                    "origin": "0x3FF90000",
                    "permissions": "rx"
                },
                {
                    "length": "0x30000",
                    "name": "internal_sram_0",
                    "origin": "0x40070000",
                    "permissions": "rwx"
                },
                {
                    "length": "0x20000",
                    "name": "internal_sram_1",
                    "origin": "0x3FFE0000",
                    "permissions": "rw"
                },
                {
                    "length": "0x32000",
                    "name": "internal_sram_2",
                    "origin": "0x3FFAE000",
                    "permissions": "rw"
                },
                {
                    "length": "0x2000",
                    "name": "rtc_fast_memory",
                    "origin": "0x3FF80000",
                    "permissions": "rwx"
                },
                {
                    "length": "0x2000",
                    "name": "rtc_slow_memory",
                    "origin": "0x50000000",
                    "permissions": "rwx"
                },
                {
                    "length": "0x400000",
                    "name": "external_flash",
                    "origin": "0x3F400000",
                    "permissions": "rx"
                },
                {
                    "length": "0x400000",
                    "name": "external_ram",
                    "origin": "0x3F800000",
                    "permissions": "rw"
                }
            ],
            "vector_alignment_section": ".vectors",
            "vector_table_offset_bytes": 0
        },
        "security_registers": {
            "flash_encryption": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": "0x3FF5B000"
            },
            "jtag_disabled": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": "0x3FF5A000"
            },
            "rdp_level": {}
        },
        "startup": {
            "abi_initialization_instructions": [
                "movi a0, 0",
                "wsr.windowbase a0",
                "rsync",
                "movi a1, _stack_top"
            ],
            "bss_init_required": true,
            "stack_top_expression": "ORIGIN(internal_sram_2) + LENGTH(internal_sram_2)"
        },
        "toolchain_requirements": {
            "compiler_prefix": "xtensa-esp32-elf-",
            "core_architecture": "Xtensa (ESP32)",
            "flashing": {
                "flash_offset": "0x1000",
                "method": "UART",
                "tool": "esptool.py",
                "write_command": "esptool.py --chip esp32 write_flash 0x1000 {binary_path}"
            },
            "packaging": [
                {
                    "command": "esptool.py --chip esp32 elf2image --flash_mode dio --flash_freq 40m --flash_size 2MB -o {binary_path} {elf_path}",
                    "condition": "ANY",
                    "tool": "esptool.py"
                },
                {
                    "command": "espsecure.py sign_data --version 2 --keyfile {private_key_path} --output {binary_path} {binary_path}",
                    "condition": "PROFILE_SECURE_BOOT_ONLY",
                    "tool": "espsecure.py"
                }
            ]
        },
        "watchdog_kill_registers": [
            {
                "address": "0x3FF5F000",
                "config_addr": null,
                "disable_val": null,
                "name": "TIMG0_WDT",
                "unlock_val": null
            },
            {
                "address": "0x3FF60000",
                "config_addr": null,
                "disable_val": null,
                "name": "TIMG1_WDT",
                "unlock_val": null
            },
            {
                "address": "0x3FF48000",
                "config_addr": null,
                "disable_val": null,
                "name": "RTC_WDT",
                "unlock_val": null
            }
        ]
    }
}