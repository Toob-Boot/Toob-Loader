{
    "esp32-c6": {
        "arch": "RISC-V",
        "boot_vectors": {
            "rom_base": "0x40000000",
            "user_app_base": "0x42000000"
        },
        "memory": {
            "dram": {
                "alignment_bytes": 16,
                "length": "0x80000",
                "origin": "0x40800000"
            },
            "iram": {
                "alignment_bytes": 16,
                "length": "0x80000",
                "origin": "0x40800000"
            }
        },
        "security_registers": {
            "flash_encryption": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": {}
            },
            "jtag_disabled": {
                "active_if_true": true,
                "bit_mask": {},
                "register_addr": {}
            },
            "rdp_level": {
                "bit_mask": {},
                "register_addr": {}
            }
        },
        "startup": {
            "abi_initialization_instructions": [
                "csrw mie, zero",
                "la gp, __global_pointer$"
            ],
            "bss_init_required": true,
            "stack_top_expression": "ORIGIN(dram) + LENGTH(dram)"
        },
        "toolchain_requirements": {
            "compiler_prefix": "riscv32-esp-elf-",
            "core_architecture": "RISC-V",
            "flashing": {
                "method": "Serial / USB-JTAG",
                "tool": "esptool.py",
                "write_command": "esptool.py write_flash 0x0 {binary_path}"
            },
            "packaging": [
                {
                    "command": "espsecure.py sign_data --version 2 --keyfile {private_key_path} --output {binary_path} {binary_path}",
                    "condition": "PROFILE_SECURE_BOOT_ONLY",
                    "tool": "espsecure.py"
                }
            ]
        },
        "watchdog_kill_registers": [
            {
                "address": "0x60008000",
                "config_addr": "0x60008048",
                "disable_val": "0x0",
                "name": "TIMG0_WDT",
                "unlock_val": "0x50D83AA1"
            },
            {
                "address": "0x60009000",
                "config_addr": "0x60009048",
                "disable_val": "0x0",
                "name": "TIMG1_WDT",
                "unlock_val": "0x50D83AA1"
            },
            {
                "address": "0x600B1C00",
                "config_addr": "0x600B1C00",
                "disable_val": "0x0",
                "name": "LP_WDT",
                "unlock_val": "0x50D83AA1"
            }
        ]
    }
}