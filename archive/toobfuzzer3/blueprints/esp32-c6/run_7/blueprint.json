        "toolchain_requirements": {
            "compiler_prefix": "riscv32-esp-elf-",
            "core_architecture": "RISC-V",
            "flashing": {
                "flash_offset": "0x0",
                "method": "UART/USB-JTAG",
                "tool": "esptool.py",
                "write_command": "esptool.py --chip esp32c6 write_flash 0x0 {binary_path}"
            },
            "packaging": [
                {
                    "command": "esptool.py --chip esp32c6 elf2image -o {binary_path} {elf_path}",
                    "condition": "ANY",
                    "tool": "esptool.py"
                },
                {
                    "command": "espsecure.py sign_data --version 2 --keyfile {private_key_path} --output {binary_path} {binary_path}",
                    "condition": "PROFILE_SECURE_BOOT_ONLY",
                    "tool": "espsecure.py"
                }
            ]
        },
        "watchdog_kill_registers": []
    }
