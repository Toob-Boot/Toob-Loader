        },
        "flash_controller": {
            "analytical_notes": "The provided document is the ESP32-C6 Datasheet, which describes high-level features, pinouts, and electrical characteristics. It lacks the register-level details for the SPI0/SPI1 Flash Controller and the BootROM API memory map. ESP32 series chips strictly dictate the use of built-in BootROM functions (e.g., esp_rom_spiflash_erase_sector) to safely interact with the SPI Flash due to cache, SMP, and timing constraints. Exact ROM pointer addresses and SPI peripheral base addresses are not present in this datasheet and require the ESP32-C6 Technical Reference Manual (TRM) and ESP-IDF ROM linker scripts to resolve.",
            "base_address": {},
            "erase_sector_sequence": [
                {
                    "args_csv": "sector_addr / 4096",
                    "desc": "Erase a 4KB sector via BootROM API",
                    "function_name": "esp_rom_spiflash_erase_sector",
                    "requires_physical_offset": true,
                    "rom_address": "UNKNOWN_ADDRESS",
                    "type": "rom_function_call"
                }
            ],
            "unlock_sequence": [
                {
                    "args_csv": "",
                    "desc": "Unlock SPI flash via BootROM API",
                    "function_name": "esp_rom_spiflash_unlock",
                    "requires_physical_offset": true,
                    "rom_address": "UNKNOWN_ADDRESS",
                    "type": "rom_function_call"
                }
            ],
            "write_word_sequence": [
                {
                    "args_csv": "sector_addr, &data_word, 4",
                    "desc": "Write data to SPI flash via BootROM API",
                    "function_name": "esp_rom_spiflash_write",
                    "requires_physical_offset": true,
                    "rom_address": "UNKNOWN_ADDRESS",
                    "type": "rom_function_call"
                }
            ]
        },
        "memory": {
            "alignment_bytes": 16,
            "bootrom_reserved_data_bytes": {},
            "data_segment": "hp_sram",
            "executable_segment": "hp_sram",
            "memory_regions": [
                {
                    "length": "0x50000",
                    "name": "rom",
                    "origin": "0x40000000",
                    "permissions": "rx"
                },
                {
                    "length": "0x80000",
                    "name": "hp_sram",
                    "origin": "0x40800000",
                    "permissions": "rwx"
                },
                {
                    "length": "0x4000",
                    "name": "lp_sram",
                    "origin": "0x50000000",
                    "permissions": "rwx"
                }
            ],
            "vector_alignment_section": ".vectors",
            "vector_table_offset_bytes": 0
        },
        "multi_core_topology": {
            "coprocessors": [
