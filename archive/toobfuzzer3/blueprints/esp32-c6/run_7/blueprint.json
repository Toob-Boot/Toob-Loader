        "startup": {
            "abi_initialization_instructions": [
                ".option push",
                ".option norelax",
                "la gp, __global_pointer$",
                ".option pop"
            ],
            "bss_init_required": true,
            "stack_top_expression": "ORIGIN(hp_sram) + LENGTH(hp_sram)"
        },
        "survival_mechanisms": {
            "needs_vbat_pin": false,
            "recommended_storage_type": "rtc_ram"
